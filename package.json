{
  "name": "@manicjs/seo",
  "version": "1.0.7",
  "description": "SEO plugin for Manic framework — robots.txt generation",
  "keywords": [
    "manic",
    "robots.txt",
    "seo"
  ],
  "homepage": "https://github.com/manic-js/plugin-seo#readme",
  "bugs": {
    "url": "https://github.com/manic-js/plugin-seo/issues"
  },
  "license": "GPL-3.0",
  "author": "Rahuletto",
  "repository": {
    "type": "git",
    "url": "https://github.com/manic-js/plugin-seo"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./metadata": {
      "types": "./src/metadata.tsx",
      "import": "./src/metadata.tsx"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "ci:lint": "bunx --bun oxlint --config .oxlintrc.json .",
    "ci:format": "bunx --bun oxfmt --check --config .oxfmt.json .",
    "ci:typecheck": "bunx --bun tsc --noEmit -p tsconfig.typecheck.json",
    "ci:build": "if bun run | grep -q \"^ build$\"; then bun run build; elif [ -f src/index.ts ]; then bun build src/index.ts --target bun --outdir .ci-build; elif [ -f index.ts ]; then bun build index.ts --target bun --outdir .ci-build; else echo \"No build entrypoint found\"; exit 1; fi",
    "ci:test": "bun run test",
    "ci:compliance": "test -f CODE_OF_CONDUCT.md && test -f LICENSE && test -f README.md",
    "test": "bun test --timeout 30000"
  },
  "devDependencies": {
    "@shikijs/transformers": "^4.0.2",
    "@types/bun": "^1.3.13",
    "@types/mdx": "^2.0.13",
    "@types/react": "^18.3.12",
    "fumadocs-docgen": "^3.0.10",
    "manicjs": "^1.0.0",
    "react": "^18.3.1"
  },
  "peerDependencies": {
    "manicjs": ">=1.0.0",
    "react": ">=18.0.0"
  }
}
