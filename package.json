{
  "name": "@manicjs/seo",
  "version": "0.5.1",
  "description": "SEO plugin for Manic framework — robots.txt generation",
  "keywords": [
    "manic",
    "robots.txt",
    "seo"
  ],
  "license": "GPL-3.0",
  "author": "Rahuletto",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rahuletto/manic"
  },
  "files": [
    "src/**/*",
    "README.md"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./metadata": {
      "types": "./src/metadata.tsx",
      "import": "./src/metadata.tsx"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "manicjs": "^0.7.4",
    "react": ">=18"
  },
  "devDependencies": {
    "@shikijs/transformers": "^4.0.2",
    "@types/mdx": "^2.0.13",
    "fumadocs-docgen": "^3.0.10"
  }
}
